<Window x:Class="Iris.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Iris.App.Converters"
        Title="Iris" Height="760" Width="1160"
        Icon="Assets/iris.ico"
        Background="{StaticResource BgBrush}">
    <Window.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImage"/>
        <conv:EnumToBoolConverter x:Key="EnumToBool"/>
        <conv:FileNameToImageConverter x:Key="FileNameToImage"/>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: controls -->
            <ScrollViewer Grid.Column="0" Margin="0,0,16,0" Padding="0,0,10,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="IRIS" Foreground="{StaticResource GoldBrush}" FontSize="30" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="  —  AI image generator" Foreground="{StaticResource MutedBrush}" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Describe your image" Foreground="{StaticResource MutedBrush}" Margin="0,20,0,6"/>
                    <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="110" TextWrapping="Wrap" VerticalContentAlignment="Top"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                             CaretBrush="{StaticResource GoldBrush}" BorderThickness="0" Padding="10"/>

                    <TextBlock Text="Style" Foreground="{StaticResource MutedBrush}" Margin="0,16,0,6"/>
                    <WrapPanel>
                        <RadioButton Content="None"           IsChecked="{Binding Style, Converter={StaticResource EnumToBool}, ConverterParameter=None}"           Foreground="{StaticResource TextBrush}" Margin="0,0,12,6"/>
                        <RadioButton Content="Photorealistic" IsChecked="{Binding Style, Converter={StaticResource EnumToBool}, ConverterParameter=Photorealistic}" Foreground="{StaticResource TextBrush}" Margin="0,0,12,6"/>
                        <RadioButton Content="Cinematic"      IsChecked="{Binding Style, Converter={StaticResource EnumToBool}, ConverterParameter=Cinematic}"      Foreground="{StaticResource TextBrush}" Margin="0,0,12,6"/>
                        <RadioButton Content="Anime"          IsChecked="{Binding Style, Converter={StaticResource EnumToBool}, ConverterParameter=Anime}"          Foreground="{StaticResource TextBrush}" Margin="0,0,12,6"/>
                        <RadioButton Content="Concept Art"    IsChecked="{Binding Style, Converter={StaticResource EnumToBool}, ConverterParameter=ConceptArt}"     Foreground="{StaticResource TextBrush}" Margin="0,0,12,6"/>
                        <RadioButton Content="3D"             IsChecked="{Binding Style, Converter={StaticResource EnumToBool}, ConverterParameter=Render3D}"       Foreground="{StaticResource TextBrush}" Margin="0,0,12,6"/>
                    </WrapPanel>

                    <TextBlock Text="Aspect" Foreground="{StaticResource MutedBrush}" Margin="0,10,0,6"/>
                    <WrapPanel>
                        <RadioButton Content="Square"    IsChecked="{Binding Aspect, Converter={StaticResource EnumToBool}, ConverterParameter=Square}"    Foreground="{StaticResource TextBrush}" Margin="0,0,14,0"/>
                        <RadioButton Content="Portrait"  IsChecked="{Binding Aspect, Converter={StaticResource EnumToBool}, ConverterParameter=Portrait}"  Foreground="{StaticResource TextBrush}" Margin="0,0,14,0"/>
                        <RadioButton Content="Landscape" IsChecked="{Binding Aspect, Converter={StaticResource EnumToBool}, ConverterParameter=Landscape}" Foreground="{StaticResource TextBrush}"/>
                    </WrapPanel>

                    <TextBlock Margin="0,16,0,6">
                        <Run Text="Seed" Foreground="{StaticResource MutedBrush}"/><Run Text="  — same seed = same image; 🎲 for a new variation" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                    </TextBlock>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="🎲" Width="42" Height="34" ToolTip="Randomize seed"
                                Command="{Binding RandomizeSeedCommand}"
                                Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0"/>
                        <TextBox Text="{Binding Seed}" Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                 CaretBrush="{StaticResource GoldBrush}" BorderThickness="0" Padding="8" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                    </DockPanel>

                    <Button Content="Generate" Style="{StaticResource GenerateButton}" Margin="0,22,0,0"
                            Command="{Binding GenerateCommand}"/>
                    <Button Content="Cancel" Margin="0,8,0,0" Height="34"
                            Command="{Binding CancelCommand}"
                            Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0"
                            Visibility="{Binding IsGenerating, Converter={x:Static conv:BoolToVis.Instance}}"/>

                    <TextBlock Text="Recent prompts" Foreground="{StaticResource MutedBrush}" Margin="0,20,0,6"
                               Visibility="{Binding HistoryItems.Count, Converter={x:Static conv:CountToVis.Instance}}"/>
                    <ItemsControl ItemsSource="{Binding HistoryItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" MaxWidth="320" Margin="0,0,6,6" Padding="8,4" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource MutedBrush}" BorderThickness="0"
                                        Command="{Binding DataContext.UseHistoryPromptCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: result -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="16">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Image Source="{Binding CurrentImage, Converter={StaticResource BytesToImage}}" Stretch="Uniform"/>
                        <TextBlock Text="Type a prompt and hit Generate" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding CurrentImage, Converter={x:Static conv:NullToVis.Instance}}"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource CrimsonBrush}"
                                   VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <!-- Generating overlay: hides the image and shows the spinner -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                Visibility="{Binding IsGenerating, Converter={x:Static conv:BoolToVis.Instance}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="58" Height="58" StrokeThickness="5" StrokeDashArray="12 5" StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{StaticResource CrimsonColor}" Offset="0"/>
                                            <GradientStop Color="{StaticResource GoldColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:1.1" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="Generating…" Foreground="{StaticResource GoldBrush}" FontSize="15" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Button Grid.Row="1" Content="Save image" HorizontalAlignment="Right" Margin="0,12,0,0"
                            Height="34" Width="120" Command="{Binding SaveCommand}" Cursor="Hand"
                            Background="{StaticResource BgBrush}" Foreground="{StaticResource GoldBrush}" BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: gallery strip (click a tile to view it) -->
        <StackPanel Grid.Row="1" Margin="0,18,0,0"
                    Visibility="{Binding GalleryItems.Count, Converter={x:Static conv:CountToVis.Instance}}">
            <TextBlock Text="Gallery" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="134" Padding="0,0,0,8">
                <ItemsControl ItemsSource="{Binding GalleryItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="118" Height="118" Margin="0,0,10,0">
                                <Button Cursor="Hand" Padding="0" BorderThickness="0" Background="Transparent" ToolTip="{Binding Prompt}"
                                        Command="{Binding DataContext.SelectGalleryItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="8" ClipToBounds="True" Background="{StaticResource BgBrush}">
                                                <Image Source="{Binding ImageFileName, Converter={StaticResource FileNameToImage}}" Stretch="UniformToFill"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="✕" Width="22" Height="22" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4" Cursor="Hand"
                                        Background="{StaticResource BgBrush}" Foreground="{StaticResource CrimsonBrush}" BorderThickness="0" FontSize="11"
                                        Command="{Binding DataContext.DeleteGalleryItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>
